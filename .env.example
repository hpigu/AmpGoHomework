# Copy to .env (or set as environment variables in your shell / Render dashboard)

# Profile: dev (H2 in-memory) or prod (PostgreSQL)
SPRING_PROFILES_ACTIVE=dev

# Public URL of this service (used to build the activation link in the email).
APP_BASE_URL=http://localhost:8080

# JWT signing secret. MUST be at least 32 bytes. Generate with:
#   openssl rand -base64 64 | tr -d '\n'
JWT_SECRET=replace-me-with-a-64-byte-random-string-replace-me-with-a-64-byte-random

# Mailtrap SMTP (Sandbox). Get these from your Sandbox -> Integration page.
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_EMAIL=no-reply@demo.local
MAIL_FROM_NAME=Auth Demo

# PostgreSQL — only needed when SPRING_PROFILES_ACTIVE=prod
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/authdb
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres
